# Anthropic is used by the researcher, verifier, and analyst agents.
# Leave empty and set PEERLANE_MOCK_LLM=1 for deterministic offline demos.
ANTHROPIC_API_KEY=

# Optional override. Defaults to claude-haiku-4-5 in backend/src/llm/client.ts.
ANTHROPIC_MODEL=

# Set to 1 when demoing without an API key.
PEERLANE_MOCK_LLM=1
